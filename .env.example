# Database
DATABASE_URL=postgresql://pra_user:pra_password@postgres:5432/pra_db

# Redis
REDIS_URL=redis://redis:6379

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_PORT=3000

# Worker
WORKER_CONCURRENCY=2

# Auth (V1 - simple)
JWT_SECRET=your-secret-key-change-in-production

# Browser automation
BROWSER_WS_ENDPOINT=ws://playwright-browsers:3000

# File storage
STORAGE_TYPE=local
STORAGE_PATH=./data/uploads

# Logging
LOG_LEVEL=debug
