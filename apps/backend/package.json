{
  "name": "@pra/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts src/migrate.ts src/seed.ts --format esm,cjs --dts false --clean",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@pra/db": "0.1.0",
    "@pra/policy-parser": "0.1.0",
    "@pra/report-generator": "0.1.0",
    "@pra/rules-engine": "0.1.0",
    "@pra/shared": "0.1.0",
    "@pra/utils": "0.1.0",
    "@pra/vendor-registry": "0.1.0",
    "bullmq": "^5.52.3",
    "drizzle-orm": "^0.43.1",
    "fastify": "^5.3.3",
    "ioredis": "^5.6.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3"
  }
}
